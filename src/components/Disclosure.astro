---
interface Props {
  question: string;
  defaultOpen?: boolean;
}
const { question, defaultOpen = false } = Astro.props as Props;
---

<details
  class="group border-rule border-b py-4 [&[open]>summary>.chevron]:rotate-90"
  open={defaultOpen}
>
  <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left">
    <span class="font-display text-h3 text-ink font-semibold">{question}</span>
    <span
      aria-hidden="true"
      class="chevron border-rule text-muted mt-1 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border transition-transform duration-150"
    >
      <svg
        viewBox="0 0 16 16"
        width="14"
        height="14"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="M6 4l4 4-4 4"></path></svg
      >
    </span>
  </summary>
  <div class="prose prose-neutral text-ink/85 mt-3 max-w-none">
    <slot />
  </div>
</details>
