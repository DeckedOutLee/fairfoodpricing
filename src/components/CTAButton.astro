---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'inverse';
  size?: 'md' | 'lg';
  download?: boolean;
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  download = false,
  external = false,
  class: className = '',
} = Astro.props as Props;

const sizes = {
  md: 'px-4 py-2 text-[0.95rem]',
  lg: 'px-6 py-3 text-base',
};

const variants = {
  primary:
    'bg-primary text-paper border border-primary hover:bg-primary-hover hover:border-primary-hover',
  secondary: 'bg-paper-elevated text-ink border border-ink/20 hover:border-ink/40',
  ghost: 'text-primary hover:text-primary-hover border border-transparent',
  inverse: 'bg-paper text-ink border border-paper hover:bg-paper-elevated',
};

const rel = external ? 'noopener noreferrer' : undefined;
const target = external ? '_blank' : undefined;
---

<a
  href={href}
  download={download}
  rel={rel}
  target={target}
  class:list={[
    'inline-flex items-center gap-2 rounded-full font-semibold no-underline transition-colors',
    sizes[size],
    variants[variant],
    className,
  ]}
>
  <slot />
  {
    external && (
      <svg
        aria-hidden="true"
        viewBox="0 0 16 16"
        width="13"
        height="13"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M6 3H3v10h10v-3M10 3h3v3M7 9l6-6" />
      </svg>
    )
  }
</a>
