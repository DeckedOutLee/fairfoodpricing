---
interface Props {
  variant?: 'inline' | 'stacked';
  tone?: 'ink' | 'paper';
  ariaLabel?: string;
  class?: string;
}

const {
  variant = 'inline',
  tone = 'ink',
  ariaLabel = 'Fair Food Pricing',
  class: className = '',
} = Astro.props;
const fill = tone === 'paper' ? 'var(--color-paper)' : 'var(--color-ink)';
const accent = tone === 'paper' ? 'var(--color-paper)' : 'var(--color-accent)';
const FONT = "'Montserrat Variable', system-ui, -apple-system, sans-serif";
---

{
  variant === 'inline' ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 300 40"
      role="img"
      aria-label={ariaLabel}
      class={className}
      width="200"
      height="27"
    >
      <text
        x="0"
        y="28"
        font-family={FONT}
        font-size="26"
        font-weight="700"
        letter-spacing="-0.018em"
        fill={fill}
      >
        Fair Food Pricing
      </text>
      <rect x="0" y="34" width="48" height="3" fill={accent} />
    </svg>
  ) : (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 240 110"
      role="img"
      aria-label={ariaLabel}
      class={className}
      width="220"
      height="100"
    >
      <rect x="0" y="0" width="60" height="4" fill={accent} />
      <text
        x="0"
        y="38"
        font-family={FONT}
        font-size="32"
        font-weight="700"
        letter-spacing="-0.018em"
        fill={fill}
      >
        Fair
      </text>
      <text
        x="0"
        y="70"
        font-family={FONT}
        font-size="32"
        font-weight="700"
        letter-spacing="-0.018em"
        fill={fill}
      >
        Food
      </text>
      <text
        x="0"
        y="102"
        font-family={FONT}
        font-size="32"
        font-weight="700"
        letter-spacing="-0.018em"
        fill={fill}
      >
        Pricing
      </text>
    </svg>
  )
}
