---
import Base from '@/layouts/Base.astro';
import CTAButton from '@/components/CTAButton.astro';
---

<Base
  title="Page not found"
  description="The page you’re looking for doesn’t exist. Here are some places to go instead."
  noIndex={true}
>
  <section class="container-wide py-20 text-center">
    <p class="text-accent font-mono text-xs font-semibold tracking-[0.18em] uppercase">404</p>
    <h1 class="font-display text-display text-ink mt-3 font-semibold">Page not found.</h1>
    <p class="text-ink/85 mx-auto mt-4 text-lg">
      The page you’re looking for has moved or never existed. The most useful pages are below.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <CTAButton href="/" variant="primary" size="lg">Go to the front page</CTAButton>
      <CTAButton href="/find-your-mp" variant="secondary" size="lg">Find your MP</CTAButton>
      <CTAButton href="/downloads" variant="secondary" size="lg">Downloads</CTAButton>
    </div>
  </section>
</Base>
