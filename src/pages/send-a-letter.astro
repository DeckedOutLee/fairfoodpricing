---
import Base from '@/layouts/Base.astro';
import PageHeader from '@/components/PageHeader.astro';
import LetterGenerator from '@/components/LetterGenerator';
---

<Base
  title="Send a letter to your MP"
  description="Generate a personalised letter to your MP about AI-driven dynamic pricing of essential food. Send by email or print and post."
>
  <PageHeader
    eyebrow="Step 2 of 2"
    title="Send your letter"
    intro="A pre-written, evidenced letter with space for your own words. Edit it, read it back, then send it by email or print it to post."
  />

  <div class="container-wide py-6 md:py-8">
    <LetterGenerator client:load />

    <noscript>
      <div class="border-rule bg-paper-elevated mt-8 rounded-2xl border p-6">
        <h2 class="font-display text-h3 font-semibold">
          JavaScript is needed for the live preview
        </h2>
        <p class="text-ink/85 mt-2">
          The letter template is generated in your browser. With JavaScript off, you can still
          download the static <a class="text-primary" href="/downloads">Word version</a> and edit it in
          Word, Pages or LibreOffice.
        </p>
      </div>
    </noscript>

    <section class="mt-8">
      <h2 class="font-display text-h2 text-ink font-semibold">What we do with your details</h2>
      <p class="text-ink/85 mt-3">
        Nothing. The letter is put together in your browser. Your name, your town, and anything you
        add yourself never reach our server.
      </p>
      <p class="text-ink/85 mt-3">
        “Send by email” opens your usual email app with the letter ready to send. “Print or save as
        PDF” opens a printable version. Your browser’s print dialog will save it as a PDF or send it
        to a printer.
      </p>
    </section>
  </div>
</Base>
